{
  "uid": "indicxlit-telemetry",
  "title": "IndicXlit Telemetry",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": [
    "indicxlit",
    "transliteration",
    "prometheus"
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (endpoint, status) (rate(xlit_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "In-flight Requests",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_http_requests_in_progress",
          "legendFormat": "in progress",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (endpoint, status) (rate(xlit_http_requests_total{status=~\"5..|4..\"}[1m]))",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Latency p50/p95/p99",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(xlit_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(xlit_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(xlit_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Inference Latency p50/p95",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, direction, lang_code, mode) (rate(xlit_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{direction}} {{lang_code}} {{mode}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, direction, lang_code, mode) (rate(xlit_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{direction}} {{lang_code}} {{mode}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Time Per Request p50/p95",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(xlit_http_request_cpu_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(xlit_http_request_cpu_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Process CPU Percent",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_process_cpu_percent",
          "legendFormat": "cpu %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Process Memory",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_process_resident_memory_bytes",
          "legendFormat": "rss",
          "refId": "A"
        },
        {
          "expr": "xlit_process_virtual_memory_bytes",
          "legendFormat": "vms",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Threads and Open FDs",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_process_threads",
          "legendFormat": "threads",
          "refId": "A"
        },
        {
          "expr": "xlit_process_open_fds",
          "legendFormat": "open fds",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GPU Utilization",
      "gridPos": {
        "x": 8,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_gpu_utilization_percent",
          "legendFormat": "gpu {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "GPU Memory Used",
      "gridPos": {
        "x": 16,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_gpu_memory_used_bytes",
          "legendFormat": "gpu {{gpu}} {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GPU Temperature and Power",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "xlit_gpu_temperature_celsius",
          "legendFormat": "temp gpu {{gpu}}",
          "refId": "A"
        },
        {
          "expr": "xlit_gpu_power_draw_watts",
          "legendFormat": "power gpu {{gpu}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    }
  ]
}