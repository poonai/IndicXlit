{
  "uid": "indicxlit-b256",
  "title": "IndicXlit b256 Rust Runtime",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rust request rate by worker",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "sum by(worker) (rate(indicxlit_http_requests_total{job=\"indicxlit-rust\",status=\"ok\"}[1m]))", "legendFormat": "{{worker}} ok"},
        {"refId": "B", "expr": "sum by(worker) (rate(indicxlit_http_requests_total{job=\"indicxlit-rust\",status=\"error\"}[1m]))", "legendFormat": "{{worker}} error"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Rust word throughput by worker",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "sum by(worker) (rate(indicxlit_http_request_words_total{job=\"indicxlit-rust\",status=\"ok\"}[1m]))", "legendFormat": "{{worker}} words/s"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"refId": "A", "expr": "indicxlit_http_request_duration_seconds{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.5\"}", "legendFormat": "{{worker}} p50"},
        {"refId": "B", "expr": "indicxlit_http_request_duration_seconds{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.95\"}", "legendFormat": "{{worker}} p95"},
        {"refId": "C", "expr": "rate(indicxlit_http_request_duration_seconds_sum{job=\"indicxlit-rust\",status=\"ok\"}[5m]) / rate(indicxlit_http_request_duration_seconds_count{job=\"indicxlit-rust\",status=\"ok\"}[5m])", "legendFormat": "{{worker}} avg"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue wait",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"refId": "A", "expr": "indicxlit_queue_wait_duration_seconds{job=\"indicxlit-rust\",quantile=\"0.5\"}", "legendFormat": "{{worker}} p50"},
        {"refId": "B", "expr": "indicxlit_queue_wait_duration_seconds{job=\"indicxlit-rust\",quantile=\"0.95\"}", "legendFormat": "{{worker}} p95"},
        {"refId": "C", "expr": "rate(indicxlit_queue_wait_duration_seconds_sum{job=\"indicxlit-rust\"}[5m]) / rate(indicxlit_queue_wait_duration_seconds_count{job=\"indicxlit-rust\"}[5m])", "legendFormat": "{{worker}} avg"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Engine batch latency",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"refId": "A", "expr": "indicxlit_batch_inference_duration_seconds{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.5\"}", "legendFormat": "{{worker}} {{mode}} p50"},
        {"refId": "B", "expr": "indicxlit_batch_inference_duration_seconds{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.95\"}", "legendFormat": "{{worker}} {{mode}} p95"},
        {"refId": "C", "expr": "rate(indicxlit_batch_inference_duration_seconds_sum{job=\"indicxlit-rust\",status=\"ok\"}[5m]) / rate(indicxlit_batch_inference_duration_seconds_count{job=\"indicxlit-rust\",status=\"ok\"}[5m])", "legendFormat": "{{worker}} {{mode}} avg"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Engine batch size",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {"refId": "A", "expr": "indicxlit_batch_words{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.5\"}", "legendFormat": "{{worker}} {{mode}} words p50"},
        {"refId": "B", "expr": "indicxlit_batch_words{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.95\"}", "legendFormat": "{{worker}} {{mode}} words p95"},
        {"refId": "C", "expr": "indicxlit_batch_requests{job=\"indicxlit-rust\",status=\"ok\",quantile=\"0.5\"}", "legendFormat": "{{worker}} {{mode}} requests p50"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "NGINX traffic",
      "gridPos": {"x": 0, "y": 24, "w": 8, "h": 8},
      "targets": [
        {"refId": "A", "expr": "nginx_connections_active", "legendFormat": "active"},
        {"refId": "B", "expr": "rate(nginx_http_requests_total[1m])", "legendFormat": "requests/s"}
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GPU utilization",
      "gridPos": {"x": 8, "y": 24, "w": 8, "h": 8},
      "targets": [
        {"refId": "A", "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU {{gpu}}"}
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GPU framebuffer memory",
      "gridPos": {"x": 16, "y": 24, "w": 8, "h": 8},
      "targets": [
        {"refId": "A", "expr": "DCGM_FI_DEV_FB_USED", "legendFormat": "used {{gpu}}"}
      ]
    }
  ]
}
